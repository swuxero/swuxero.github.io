},{"code":101,"indent":0,"parameters":["",0,0,2,"수사관"]},{"code":401,"indent":0,"parameters":["오늘 많이 힘드셨죠."]},{"code":401,"indent":0,"parameters":["여기까지 오는 게 쉽지 않았을 텐데."]},{"code":231,"indent":0,"parameters":[10,"주인공_질끈",0,0,0,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[11]},{"code":101,"indent":0,"parameters":["",0,0,2,"유진"]},{"code":401,"indent":0,"parameters":["여기까지 왔는데도 아직 무서워요."]},{"code":401,"indent":0,"parameters":["신고하면 더 알려지는 거 아닌가 싶어서."]},{"code":231,"indent":0,"parameters":[11,"경찰_무표정",0,0,591,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[10]},{"code":101,"indent":0,"parameters":["",0,0,2,"수사관"]},{"code":401,"indent":0,"parameters":["그 걱정은 당연합니다."]},{"code":401,"indent":0,"parameters":["수사 과정에서 피해자 신원은 철저하게 보호하고,"]},{"code":401,"indent":0,"parameters":["필요한 범위에서만 확인하겠습니다."]},{"code":111,"indent":0,"parameters":[0,4,1]},{"code":231,"indent":1,"parameters":[11,"경찰_무표정",0,0,591,249,75,75,255,0]},{"code":235,"indent":1,"parameters":[10]},{"code":101,"indent":1,"parameters":["",0,0,2,"수사관"]},{"code":401,"indent":1,"parameters":["친구분은 대기실에서 기다리셔도 됩니다."]},{"code":401,"indent":1,"parameters":["유진님이 동의한 자료만 수사 기록에 포함하겠습니다."]},{"code":101,"indent":1,"parameters":["",0,0,2,"수사관"]},{"code":401,"indent":1,"parameters":["친구분이 받은 유포 DM은 제출 가능하지만,"]},{"code":401,"indent":1,"parameters":["그 과정도 두 분 모두의 동의가 필요합니다."]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,"수사관"]},{"code":401,"indent":1,"parameters":["혼자 오셨어도 괜찮습니다."]},{"code":401,"indent":1,"parameters":["원하시면 피해자 전담요원이나"]},{"code":401,"indent":1,"parameters":["상담기관 연계도 함께 안내하겠습니다."]},{"code":101,"indent":1,"parameters":["",0,0,2,"수사관"]},{"code":401,"indent":1,"parameters":["조사 과정에서 불안해지면 언제든 쉬어가도 됩니다."]},{"code":401,"indent":1,"parameters":["유진님의 신원과 진술은 필요한 범위 안에서 보호하겠습니다."]},{"code":412,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[11,"경찰_무표정",0,0,591,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[10]},{"code":111,"indent":0,"pa
{"code":401,"indent":0,"parameters":["상담 예약하셨나요?"]},{"code":231,"indent":0,"parameters":[10,"주인공_낙담",0,0,0,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[11]},{"code":101,"indent":0,"parameters":["",0,0,2,"유진"]},{"code":401,"indent":0,"parameters":["아니요. 인권센터에서 약도 받고 바로 왔어요."]},{"code":231,"indent":0,"parameters":[10,"주인공_낙담",0,0,0,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[11]},{"code":101,"indent":0,"parameters":["",0,0,2,"직원"]},{"code":401,"indent":0,"parameters":["네, 괜찮아요. 지금 많이 긴장되실 수 있어요."]},{"code":101,"indent":0,"parameters":["",0,0,2,"직원"]},{"code":401,"indent":0,"parameters":["바로 담당 상담원께 연결해 드릴게요."]},{"code":111,"indent":0,"parameters":[0,4,1]},{"code":231,"indent":1,"parameters":[11,"수아_슬픔",0,0,591,249,75,75,255,0]},{"code":235,"indent":1,"parameters":[10]},{"code":101,"indent":1,"parameters":["",0,0,2,"수아"]},{"code":401,"indent":1,"parameters":["나는 밖에서 기다릴게."]},{"code":401,"indent":1,"parameters":["네가 원하지 않는 이야기는 내가 듣지 않을게."]},{"code":231,"indent":1,"parameters":[10,"주인공_낙담",0,0,0,249,75,75,255,0]},{"code":235,"indent":1,"parameters":[11]},{"code":101,"indent":1,"parameters":["",0,0,2,"유진"]},{"code":401,"indent":1,"parameters":["...응. 끝나면 나와서 말할게."]},{"code":235,"indent":1,"parameters":[10]},{"code":235,"indent":1,"parameters":[11]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["대기실 의자들이 조용히 놓여 있었다."]},{"code":401,"indent":1,"parameters":["혼자 앉아 있으니 핸드폰을 쥔 손에 더 힘이 들어갔다."]},{"code":412,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[11,"형사_미소",0,0,591,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[10]},{"code":101,"indent":0,"parameters":["",0,0,2,"상담원"]},{"code":401,"indent":0,"parameters":["안녕하세요. 서두르지 않아도 됩니다."]},{"code":401,"indent":0,"parameters":["필요한 만큼 쉬면서 말해 주세요."]},{"code":231,"indent":0,"parameters":[10,"주인공_질끈",0,0,0,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[11]},{"code":101,"indent":0,"parameters":["",0,0,2,"유진"]},{"code":401,"indent":0,"parameters":["친구랑 찍은 사진이 인스타에 올라갔는데,"]},{"code":401,"indent":0,"parameters":["그게 딥페이크에 쓰인 것 같아요."]},{"code":401,"indent":0,"parameters":["텔레그램에 퍼지고 있다는 연락을 어젯밤에 받았어요."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["말할 때마다 그 화면을 다시 보는 것 같았다."]},{"code":401,"indent":0,"parameters":["내 목소리가 자꾸 작아졌다."]},{"code":231,"indent":0,"parameters":[11,"형사_미소",0,0,591,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[10]},{"code":101,"indent":0,"parameters":["",0,0,2,"상담원"]},{"code":401,"indent":0,"parameters":["여기까지 오는 동안 몸과 마음이 계속 긴장했을 거예요."]},{"code":401,"indent":0,"parameters":["지금은 안전한 절차 안에서 함께 확인하겠습니다."]},{"code":101,"indent":0,"parameters":["",0,0,2,"상담원"]},{"code":401,"indent":0,"parameters":["당장 지우고 싶은 마음이 드는 건 당연해요."]},{"code":401,"indent":0,"parameters":["다만 유진님을 더 보호하기 위해,"]},{"code":401,"indent":0,"parameters":["수사기관에 제출할 채증 자료를 함께 정리하겠습니다."]},{"code":231,"indent":0,"parameters":[10,"주인공_질끈",0,0,0,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[11]},{"code":101,"indent":0,"parameters":["",0,0,2,"유진"]},{"code":401,"indent":0,"parameters":["그 화면을 다시 봐야 한다는 게 너무 무서워요."]},{"code":401,"indent":0,"parameters":["제가 버틸 수 있을까요?"]},{"code":231,"indent":0,"parameters":[11,"형사_미소",0,0,591,249,75,75,255,0]},{"code":235,"indent":0,"parameters":[10]},{"code":101,"indent":0,"parameters":["",0,0,2,"상담원"]},{"code":401,"indent":0,"parameters":["그 두려움을 억지로 밀어내지 않아도 됩니다."]},{"code":401,"indent":0,"parameters":["여기서의 채증은 경찰 수사를 대신하는 게 아니라,"]},{"code":401,"indent":0,"parameters":["삭제 요청과 신고에 필요한 자료를"]},{"code":401,"indent":0,"parameters":["안전하게 정리하는 과정이에요."]},{"code":401,"indent":0,"parameters":["삭제는 저희가 플랫폼에 직접 요청할 수 있어요."]},{"code":401,"indent":0,"parameters":["필요한 부분만 함께 확인하고, 힘들면 언제든 멈춰도 됩니다."]},{"code":111,"indent":0,"parameters":[0,4,1]},{"code":231,"indent":1,"parameters":[11,"형사_미소",0,0,591,249,75,75,255,0]},{"code":235,"indent":1,"parameters":[10]},{"code":101,"indent":1,"parameters":["",0,0